# Google Maps JavaScript API key
# Get one at: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Places API, Geometry Library
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Spring server URL
# For web dev: http://localhost:8088
# For RC Pro controller (same WiFi as laptop): http://LAPTOP_IP:8088
EXPO_PUBLIC_WAYPOINTMAP_API_BASE_URL=http://localhost:8088
